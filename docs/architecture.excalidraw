    { "type": "text", "id": "blk_t", "x": 58, "y": 532, "width": 310, "height": 24, "text": "BLOCKED — deny by default", "fontSize": 15, "fontFamily": 2, "strokeColor": "#000000", "backgroundColor": "transparent", "textAlign": "left", "verticalAlign": "top" },
