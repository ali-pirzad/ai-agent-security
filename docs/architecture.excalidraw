    { "type": "text", "id": "apim_b", "x": 450, "y": 286, "width": 224, "height": 150, "text": "• subscription key auth\n• rate-limit 20 / 60s\n• request validation\n• logging → App Insights\n\npublic gateway, VNet-injected", "fontSize": 12, "fontFamily": 2, "strokeColor": "#000000", "backgroundColor": "transparent", "textAlign": "left", "verticalAlign": "top" },

