  "elements": [
    { "type": "text", "id": "title", "x": 40, "y": 20, "width": 1300, "height": 40, "text": "Secure AI Agents on Azure — Zero-Trust Egress Governance", "fontSize": 30, "fontFamily": 2, "strokeColor": "#000000", "backgroundColor": "transparent", "textAlign": "left", "verticalAlign": "top" },
    { "type": "text", "id": "subtitle", "x": 40, "y": 70, "width": 1300, "height": 28, "text": "Copilot Studio & Azure AI Foundry agents behind ONE governed perimeter — APIM + VNet + private endpoints", "fontSize": 16, "fontFamily": 2, "strokeColor": "#000000", "backgroundColor": "transparent", "textAlign": "left", "verticalAlign": "top" },

